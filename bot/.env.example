# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_BOT_USERNAME=your_bot_username_here

# Groq AI Configuration (for Whisper transcription + Llama analysis)
GROQ_API_KEY=your_groq_api_key_here
GROQ_TRANSCRIPTION_MODEL=whisper-large-v3-turbo
GROQ_ANALYSIS_MODEL=llama-3.1-8b-instant

# PocketBase Configuration
POCKETBASE_URL=http://your-pocketbase-url:8090
POCKETBASE_ADMIN_EMAIL=admin@example.com
POCKETBASE_ADMIN_PASSWORD=your_admin_password_here

# Web Dashboard URL — used in /weblogin magic links
WEB_APP_URL=https://ai-notes-meeting.vercel.app/

# Optional: Alternative AI Models (if using different providers)
CEREBRAS_API_KEY=optional_cerebras_api_key
CEREBRAS_MODEL=optional_cerebras_model
GEMINI_API_KEY=optional_gemini_api_key
GEMINI_MODEL=optional_gemini_model